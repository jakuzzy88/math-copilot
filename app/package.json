{
  "name": "math-copilot-app",
  "version": "0.1.0",
  "private": true,
  "description": "Offline Handwritten Math Copilot – React Native app",
  "main": "index.js",
  "scripts": {
    "start": "react-native start",
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "bundle:android": "react-native bundle --platform android --dev false --entry-file index.js --bundle-output android/app/src/main/assets/index.android.bundle --assets-dest android/app/src/main/res",
    "assemble:release": "cd android && ./gradlew assembleRelease",
    "build:release-apk": "npm run bundle:android && npm run assemble:release",
    "test": "jest --verbose",
    "test:watch": "jest --watch",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "math",
    "handwriting",
    "offline",
    "react-native"
  ],
  "license": "MIT",
  "devDependencies": {
    "@react-native-community/cli": "^20.2.0",
    "@react-native-community/cli-platform-android": "^20.2.0",
    "@react-native/babel-preset": "^0.86.0",
    "@react-native/metro-config": "^0.86.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "@types/react-native": "^0.72.8",
    "jest": "^30.4.2",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "onnxruntime-react-native": "^1.24.3",
    "react": "^19.2.7",
    "react-native": "^0.86.0",
    "react-native-vision-camera": "^5.1.0"
  }
}
